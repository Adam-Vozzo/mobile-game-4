{
  "name": "neon-drift",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Mobile-first PWA twin-stick shooter in the Geometry Wars vein. Pure vector, neon, glow, lavish particles.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "bundle:size": "node scripts/bundle-size.mjs"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "pixi.js": "^7.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/howler": "^2.2.11",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^1.5.0",
    "workbox-window": "^7.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
